<dashboard version="1.1" theme="dark">
  <label>Linux Authentication Analytics</label>
  <row>
    <panel>
      <title>Total Failed Login Attempts</title>
      <single>
        <title>Total Failed Login Attempts</title>
        <search>
          <query>index=linux_logs sourcetype=linux_secure "Failed password" | stats count as "Failed Logins"</query>
          <earliest>-7d@h</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="height">104</option>
        <option name="rangeColors">["0x53a051","0x0877a6","0xf8be34","0xf1813f","0xdc4e41"]</option>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <title>Failed Login Timeline</title>
      <chart>
        <title>Failed Login Timeline</title>
        <search>
          <query>index=linux_logs sourcetype=linux_secure Failed
| timechart count as "Failed Attempts"</query>
          <earliest>-7d@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Top Attacking Source IPs</title>
        <search>
          <query>index=linux_logs sourcetype=linux_secure Failed
| rex field=_raw "from (?&lt;src_ip&gt;\d+\.\d+\.\d+\.\d+)"
| stats count by src_ip
| sort -count
| head 10</query>
          <earliest>-7d@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Top Targeted Usernames</title>
        <search>
          <query>index=linux_logs sourcetype=linux_secure Failed
| rex field=_raw "for (?&lt;username&gt;\w+) from"
| stats count by username
| sort -count
| head 10</query>
          <earliest>-7d@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <single>
        <title>Successful SSH Logins</title>
        <search>
          <query>index=linux_logs sourcetype=linux_secure Accepted
| stats count as "Successful Logins"</query>
          <earliest>-7d@h</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Authentication Events by Hour</title>
        <search>
          <query>index=linux_logs sourcetype=linux_secure
| eval hour=strftime(_time, "%H")
| stats count by hour
| sort hour</query>
          <earliest>-7d@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
</dashboard>